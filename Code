        function Footer({ darkMode }) {
            return (
                <footer className={`py-16 ${darkMode ? 'bg-black border-t border-gray-800' : 'bg-gray-100 border-t border-gray-300'}`}>
                    <div className="max-w-7xl mx-auto px-6">
