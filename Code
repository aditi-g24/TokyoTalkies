                            <div>
                                <h3 className={`font-display text-2xl font-bold mb-4 ${darkMode ? 'text-white' : 'text-black'}`}>TOKYO TALKIES</h3>
                                <p className={`${darkMode ? 'text-gray-400' : 'text-gray-600'}`}>
                                    Redefining street fashion with elegance and innovation.
                                </p>
                            </div>
                            <div>
                                <h4 className={`font-semibold mb-4 ${darkMode ? 'text-white' : 'text-black'}`}>Shop</h4>
                                <ul className="space-y-2">
                                    <li><a href="#" className={`hover:opacity-70 transition ${darkMode ? 'text-gray-400' : 'text-gray-600'}`}>New Arrivals</a></li>
                                    <li><a href="#" className={`hover:opacity-70 transition ${darkMode ? 'text-gray-400' : 'text-gray-600'}`}>Dresses</a></li>
                                    <li><a href="#" className={`hover:opacity-70 transition ${darkMode ? 'text-gray-400' : 'text-gray-600'}`}>Tops</a></li>
                                    <li><a href="#" className={`hover:opacity-70 transition ${darkMode ? 'text-gray-400' : 'text-gray-600'}`}>Accessories</a></li>
                                </ul>
                            </div>
                            <div>
                                <h4 className={`font-semibold mb-4 ${darkMode ? 'text-white' : 'text-black'}`}>Support</h4>
                                <ul className="space-y-2">
                                    <li><a href="#" className={`hover:opacity-70 transition ${darkMode ? 'text-gray-400' : 'text-gray-600'}`}>Contact Us</a></li>
                                    <li><a href="#" className={`hover:opacity-70 transition ${darkMode ? 'text-gray-400' : 'text-gray-600'}`}>Shipping Info</a></li>
                                    <li><a href="#" className={`hover:opacity-70 transition ${darkMode ? 'text-gray-400' : 'text-gray-600'}`}>Returns</a></li>
                                    <li><a href="#" className={`hover:opacity-70 transition ${darkMode ? 'text-gray-400' : 'text-gray-600'}`}>FAQ</a></li>
                                </ul>
                            </div>
                            <div>
                                <h4 className={`font-semibold mb-4 ${darkMode ? 'text-white' : 'text-black'}`}>Follow Us</h4>
                                <div className="flex space-x-4">
                                    <a href="#" className={`text-2xl hover:scale-110 transition-transform ${darkMode ? 'text-gray-400' : 'text-gray-600'}`}>
                                        <i className="fab fa-instagram"></i>
                                    </a>
                                    <a href="#" className={`text-2xl hover:scale-110 transition-transform ${darkMode ? 'text-gray-400' : 'text-gray-600'}`}>
                                        <i className="fab fa-facebook"></i>
                                    </a>
                                    <a href="#" className={`text-2xl hover:scale-110 transition-transform ${darkMode ? 'text-gray-400' : 'text-gray-600'}`}>
                                        <i className="fab fa-twitter"></i>
                                    </a>
                                    <a href="#" className={`text-2xl hover:scale-110 transition-transform ${darkMode ? 'text-gray-400' : 'text-gray-600'}`}>
                                        <i className="fab fa-pinterest"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                        <div className={`text-center pt-8 border-t ${darkMode ? 'border-gray-800 text-gray-400' : 'border-gray-300 text-gray-600'}`}>
                            <p>&copy; 2024 Tokyo Talkies. All rights reserved.</p>
                        </div>
                    </div>
                </footer>
            );
        }

        // Render App
        ReactDOM.render(<App />, document.getElementById('root'));
    </script>
