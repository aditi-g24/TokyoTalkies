                                            {[...Array(testimonial.rating)].map((_, i) => (
                                                <i key={i} className="fas fa-star text-yellow-400 text-2xl mx-1"></i>
                                            ))}
                                        </div>
                                        <p className={`text-xl md:text-2xl italic mb-6 ${darkMode ? 'text-gray-300' : 'text-gray-700'}`}>
                                            "{testimonial.text}"
                                        </p>
                                        <h4 className={`font-semibold text-xl ${darkMode ? 'text-white' : 'text-black'}`}>{testimonial.name}</h4>
                                        <p className={`${darkMode ? 'text-gray-400' : 'text-gray-600'}`}>{testimonial.role}</p>
                                    </div>
                                </div>
                            ))}

                            <div className="flex justify-center mt-8 space-x-2">
                                {testimonials.map((_, index) => (
                                    <button
                                        key={index}
                                        onClick={() => setCurrentIndex(index)}
                                        className={`w-3 h-3 rounded-full transition-all ${index === currentIndex ? 'bg-purple-500 w-8' : darkMode ? 'bg-gray-600' : 'bg-gray-300'}`}
                                    />
                                ))}
                            </div>
                        </div>
                    </div>
                </section>
            );
        }

        // Newsletter
        function Newsletter({ darkMode }) {
            return (
                <section className={`py-20 ${darkMode ? 'bg-gradient-to-r from-purple-900 to-pink-900' : 'bg-gradient-to-r from-purple-200 to-pink-200'}`}>
                    <div className="max-w-4xl mx-auto px-6 text-center">
                        <h2 className={`font-display text-4xl md:text-5xl font-bold mb-4 animate-fadeInUp ${darkMode ? 'text-white' : 'text-gray-900'}`}>
                            Join Our Fashion Community
                        </h2>
                        <p className={`text-lg mb-8 animate-fadeInUp ${darkMode ? 'text-gray-200' : 'text-gray-800'}`}>
                            Subscribe to get exclusive access to new arrivals, special offers, and style tips
                        </p>
                        <div className="flex flex-col sm:flex-row gap-4 max-w-md mx-auto animate-fadeInUp">
                            <input 
                                type="email" 
                                placeholder="Enter your email" 
                                className={`flex-1 px-6 py-4 rounded-full focus:outline-none focus:ring-2 focus:ring-purple-500 ${darkMode ? 'bg-gray-800 text-white' : 'bg-white text-black'}`}
                            />
                            <button className="btn-primary px-8 py-4 bg-black text-white font-semibold rounded-full hover:scale-105 transition-transform">
                                Subscribe
                            </button>
                        </div>
                    </div>
                </section>
            );
        }

