                                    key={index}
                                    className={`transition-opacity duration-500 ${index === currentIndex ? 'opacity-100' : 'opacity-0 absolute inset-0'}`}
                                >
                                    <div className={`text-center p-12 rounded-2xl ${darkMode ? 'bg-gray-900' : 'bg-gray-50'}`}>
